# Copy to .env (`cp .env.example .env`). Every value here has a working default in
# the compose files, so the stack runs even without a .env — this file just lets you
# see and change everything in one place.

# --- DHIS2 database credentials (compose.yml) ---
# (DB_HOSTNAME is intentionally not set — it defaults to the dhis2-db service name.)
DB_NAME=dhis
DB_USERNAME=dhis
DB_PASSWORD=dhis

# --- Analytics ---
# 1 = generate the analytics_* tables on startup (needed by the Data Visualizer,
# Climate app, and the CHAP Modelling App). 0 = skip it for a faster startup.
DHIS2_ANALYTICS=1

# --- chap-core (compose.chap.yml) ---
POSTGRES_USER=chap
POSTGRES_PASSWORD=chap
POSTGRES_DB=chap_core
# DHIS2 admin used by the route one-shot:
DHIS2_ADMIN_USER=admin
DHIS2_ADMIN_PASSWORD=district
# FastAPI root_path for chap-core. chap is reached through the DHIS2 route at
# /api/routes/chap/run/**, so this prefix is what makes the proxied Swagger UI and
# OpenAPI work — i.e. http://localhost:8080/api/routes/chap/run/docs. Change it only
# if you change the route code (default route code is "chap").
CHAP_ROOT_PATH=/api/routes/chap/run

# --- Published host ports (all bound to 127.0.0.1) ---
# Override per stack to avoid clashes with other compose setups on this machine.
DHIS2_PORT=8080        # DHIS2 web UI/API
DHIS2_DB_PORT=15432    # DHIS2 PostGIS — connect psql/DBeaver to the DHIS2 database
CHAP_DB_PORT=15433     # chap-core Postgres — connect psql/DBeaver to the chap database
#
# Connect a SQL client to the data (after `make start-chap`):
#   DHIS2:  host 127.0.0.1  port 15432  db dhis        user dhis  pass dhis
#   chap:   host 127.0.0.1  port 15433  db chap_core   user chap  pass chap
#
# chap-core itself is not published — DHIS2 reaches it internally via the "chap"
# route. To let other machines connect to a DB, drop the "127.0.0.1:" prefix on
# that service's `ports:` in the compose file.
